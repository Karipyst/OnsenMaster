<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>温泉マップ</title>
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">

<link href="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.css" rel="stylesheet" />
<script src="https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.js"></script>

<style>
:root{
  --accent:#34c759;
  --blue:#007aff;
  --danger:#ff3b30;
  --text:#1f2937;
  --sub:#6b7280;
  --card-bg:rgba(255,255,255,.14);
  --border:rgba(255,255,255,.18);
}

*{box-sizing:border-box;}
html,body{height:100%;}
body{
  margin:0;
  font-family:-apple-system,BlinkMacSystemFont,"Hiragino Sans","Yu Gothic UI",sans-serif;
  background:#f2f2f7;
  color:var(--text);
}
button,input,select{font:inherit;}

/* ローディング */
#loading{
  position:fixed;inset:0;
  display:flex;justify-content:center;align-items:center;
  background:rgba(0,0,0,0.25);
  opacity:0;pointer-events:none;transition:.3s;
  z-index:2000;
}
#loading.active{opacity:1;pointer-events:auto;}
.spinner{
  width:40px;height:40px;
  border:4px solid #fff;border-top:4px solid transparent;
  border-radius:50%;animation:spin 1s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg);}}

/* 認証 */
#auth{
  position:fixed;
  inset:0;
  display:flex;
  justify-content:center;
  align-items:center;
  background:
    linear-gradient(rgba(0,0,0,.35), rgba(0,0,0,.48)),
    url("login-bg.jpg") center center / cover no-repeat;
  z-index:1000;
  transition:.6s;
}

.auth-card{
  backdrop-filter:blur(20px);
  background:var(--card-bg);
  border:1px solid var(--border);
  padding:30px;
  border-radius:22px;
  width:min(340px, calc(100vw - 32px));
  text-align:center;
  box-shadow:0 20px 60px rgba(0,0,0,.22);
}
.auth-card h3{
  margin:0 0 8px;
  color:#fff;
  font-size:26px;
}
.auth-card p{
  margin:0 0 20px;
  color:rgba(255,255,255,.84);
  font-size:14px;
}
.auth-card form{
  display:flex;
  flex-direction:column;
  gap:10px;
}
.auth-card input,
.auth-card button{
  width:100%;
  padding:13px 14px;
  border-radius:12px;
  border:none;
  font-size:15px;
}
.auth-card input{
  background:rgba(255,255,255,.92);
}
.auth-card button{
  background:var(--accent);
  color:#fff;
  font-weight:700;
  cursor:pointer;
}
.auth-card .auth-hint{
  margin-top:10px;
  color:rgba(255,255,255,.75);
  font-size:12px;
}

/* 本体 */
#app{
  position:fixed;
  inset:0;
  opacity:0;
  transform:translateY(20px) scale(.98);
  transition:opacity .6s ease, transform .6s ease;
}

/* マップ */
#map{
  position:fixed;
  top:0;
  width:100%;
  height:65vh;
}

/* PC下部リスト */
.main{
  margin-top:65vh;
  padding:12px 12px calc(80px + env(safe-area-inset-bottom));
}
.selected-panel{
  background:#fff;
  border-radius:16px;
  box-shadow:0 8px 28px rgba(15,23,42,.08);
  padding:12px;
}
.selected-title{
  font-size:14px;
  font-weight:700;
  margin-bottom:10px;
}
#selected{
  max-height:220px;
  overflow-y:auto;
}
.empty-note{
  color:var(--sub);
  font-size:14px;
  padding:8px 4px;
}
.selected-item{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:12px;
  padding:10px;
  margin:6px 0;
  background:#f8fafc;
  border-radius:12px;
  transition:.25s;
}
.selected-item-info{display:flex;flex-direction:column;gap:3px;min-width:0;}
.selected-item-title{font-size:14px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.selected-item-meta{font-size:12px;color:var(--sub);}
.remove-btn{
  width:28px;height:28px;
  min-width:28px;
  border-radius:50%;
  background:#e5e7eb;
  display:flex;align-items:center;justify-content:center;
  border:none;
  cursor:pointer;
}

/* フッター */
.footer{
  position:fixed;
  bottom:0;
  left:0;
  width:100%;
  display:flex;
  justify-content:space-around;
  align-items:center;
  background:rgba(255,255,255,0.95);
  backdrop-filter:blur(20px);
  border-top:1px solid #ddd;
  z-index:1000;
  padding-bottom:env(safe-area-inset-bottom);
  height:calc(60px + env(safe-area-inset-bottom));
}
.icon-btn{
  flex:1;
  height:100%;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  border:none;
  background:none;
  padding:0;
  font-size:10px;
  color:#333;
  cursor:pointer;
}
.icon-btn svg{
  width:22px;
  height:22px;
  stroke:#333;
  fill:none;
  stroke-width:2;
}
.icon-btn span{margin-top:2px;}
.icon-btn.active svg{stroke:var(--accent);}
.route-btn svg{stroke:var(--blue);}
.opt-btn svg{stroke:var(--accent);}
.clear-btn svg{stroke:var(--danger);}

/* メニューボタン */
.menu-toggle{
  position:fixed;
  top:max(16px, env(safe-area-inset-top));
  left:16px;
  z-index:1300;
  width:46px;
  height:46px;
  border:none;
  border-radius:16px;
  background:rgba(255,255,255,.94);
  backdrop-filter:blur(12px);
  box-shadow:0 12px 28px rgba(15,23,42,.18);
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
}
.menu-toggle svg{
  width:22px;height:22px;stroke:#111827;fill:none;stroke-width:2;
}

/* サイドメニュー */
.side-menu{
  position:fixed;
  inset:0 auto 0 0;
  width:min(380px, 88vw);
  height:100dvh;
  background:#fff;
  z-index:1500;
  transform:translateX(-100%);
  transition:transform .35s ease;
  box-shadow:10px 0 28px rgba(0,0,0,.18);
  display:flex;
  flex-direction:column;
}
.side-menu.open{transform:translateX(0);}
.menu-overlay{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.28);
  opacity:0;
  pointer-events:none;
  transition:opacity .25s ease;
  z-index:1400;
}
.menu-overlay.show{
  opacity:1;
  pointer-events:auto;
}
.menu-header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:12px;
  padding:18px 16px 14px;
  border-bottom:1px solid #eef2f7;
}
.menu-header h3{margin:0;font-size:20px;}
.menu-close{
  border:none;
  background:#f3f4f6;
  width:36px;height:36px;border-radius:12px;
  cursor:pointer;
}
.menu-scroll{
  overflow-y:auto;
  padding:14px 14px 28px;
}
.menu-block{
  margin-bottom:14px;
  background:#f8fafc;
  border:1px solid #eef2f7;
  border-radius:16px;
  padding:12px;
}
.menu-block h4{
  margin:0 0 10px;
  font-size:14px;
}
.menu-grid{
  display:grid;
  gap:10px;
}
.menu-grid input,
.menu-grid select{
  width:100%;
  padding:11px 12px;
  border-radius:12px;
  border:1px solid #dbe2ea;
  background:#fff;
}
.menu-note{
  margin-top:8px;
  color:var(--sub);
  font-size:12px;
  line-height:1.5;
}
.onsen-list{
  display:flex;
  flex-direction:column;
  gap:10px;
}
.onsen-item{
  background:#fff;
  border:1px solid #e5e7eb;
  border-radius:14px;
  padding:12px;
  display:flex;
  flex-direction:column;
  gap:10px;
}
.onsen-head{
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  gap:8px;
}
.onsen-name{
  font-weight:700;
  font-size:15px;
}
.onsen-type{
  display:inline-flex;
  align-items:center;
  gap:6px;
  font-size:12px;
  color:var(--sub);
  margin-top:4px;
}
.onsen-type-dot{
  width:10px;height:10px;border-radius:50%;display:inline-block;
}
.onsen-mini{
  display:grid;
  grid-template-columns:repeat(2,minmax(0,1fr));
  gap:6px 10px;
  font-size:12px;
  color:#374151;
}
.onsen-mini div{
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
}
.onsen-actions{
  display:flex;
  gap:8px;
}
.ghost-btn,.solid-btn{
  flex:1;
  height:38px;
  border-radius:12px;
  border:none;
  cursor:pointer;
  font-weight:700;
}
.ghost-btn{
  background:#eef2ff;
  color:#1d4ed8;
}
.solid-btn{
  background:var(--accent);
  color:#fff;
}
.solid-btn.is-selected{
  background:#111827;
}
.no-result{
  color:var(--sub);
  text-align:center;
  padding:18px 8px;
  font-size:14px;
}



/* 詳細シート */
.detail-sheet{
  position:fixed;
  left:0;
  right:0;
  bottom:0;
  z-index:1600;
  background:rgba(255,255,255,.98);
  backdrop-filter:blur(18px);
  border-top-left-radius:24px;
  border-top-right-radius:24px;
  box-shadow:0 -16px 40px rgba(15,23,42,.18);
  transform:translateY(calc(100% + 24px));
  transition:transform .35s ease;
  max-height:min(72dvh, 640px);
  display:flex;
  flex-direction:column;
}
.detail-sheet.open{transform:translateY(0);}
.detail-overlay{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.2);
  opacity:0;
  pointer-events:none;
  transition:opacity .25s ease;
  z-index:1550;
}
.detail-overlay.show{
  opacity:1;
  pointer-events:auto;
}
.detail-head{
  position:sticky;
  top:0;
  background:linear-gradient(rgba(255,255,255,.98), rgba(255,255,255,.95));
  padding:10px 16px 8px;
  border-bottom:1px solid #eef2f7;
}
.detail-handle{
  width:44px;
  height:5px;
  background:#d1d5db;
  border-radius:999px;
  margin:0 auto 10px;
}
.detail-title-row{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
}
.detail-title{
  font-size:20px;
  font-weight:800;
  margin:0;
}
.detail-close{
  width:38px;
  height:38px;
  border:none;
  border-radius:12px;
  background:#f3f4f6;
  cursor:pointer;
  font-size:20px;
}
.detail-body{
  overflow-y:auto;
  padding:16px 16px calc(22px + env(safe-area-inset-bottom));
}
.detail-badges{
  display:flex;
  flex-wrap:wrap;
  gap:8px;
  margin:10px 0 14px;
}
.detail-badge{
  display:inline-flex;
  align-items:center;
  gap:6px;
  height:32px;
  padding:0 12px;
  border-radius:999px;
  background:#f8fafc;
  border:1px solid #e5e7eb;
  font-size:13px;
}
.detail-section{
  background:#f8fafc;
  border:1px solid #eef2f7;
  border-radius:16px;
  padding:14px;
  margin-bottom:12px;
}
.detail-section h4{
  margin:0 0 10px;
  font-size:14px;
}
.detail-grid{
  display:grid;
  grid-template-columns:repeat(2,minmax(0,1fr));
  gap:10px;
}
.detail-field{
  min-width:0;
}
.detail-label{
  display:block;
  font-size:12px;
  color:var(--sub);
  margin-bottom:5px;
}
.detail-value{
  font-size:14px;
  color:#111827;
  line-height:1.55;
  word-break:break-word;
}
.detail-actions{
  display:flex;
  gap:10px;
  margin-top:16px;
}
.detail-link{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  width:100%;
  height:42px;
  border-radius:12px;
  background:#111827;
  color:#fff;
  text-decoration:none;
  font-weight:700;
}
@media (max-width:520px){
  .detail-grid{grid-template-columns:1fr;}
}

/* 極小画面 */
@media (max-width:400px){
  .icon-btn span{display:none;}
}

/* モバイル */
.mobile #map{height:100dvh;}
.mobile .main{display:none;}
</style>
</head>

<body>
<div id="loading"><div class="spinner"></div></div>

<div id="auth">
  <div class="auth-card">
    <h3>Sommelier Map</h3>
    <p>Enterキーでもログインできます</p>
    <form onsubmit="event.preventDefault(); login();">
      <input type="password" id="pw" placeholder="パスワード" autocomplete="current-password">
      <button type="submit">ログイン</button>
    </form>
    <div class="auth-hint">背景画像は login-bg.jpg を同じ階層に配置してください</div>
  </div>
</div>

<div id="app">
  <button id="menuToggle" class="menu-toggle" onclick="toggleMenu()" aria-label="メニューを開く">
    <svg viewBox="0 0 24 24">
      <path d="M4 7h16M4 12h16M4 17h16"/>
    </svg>
  </button>

  <div id="menuOverlay" class="menu-overlay" onclick="closeMenu()"></div>

  <aside id="sideMenu" class="side-menu" aria-hidden="true">
    <div class="menu-header">
      <h3>温泉メニュー</h3>
      <button class="menu-close" onclick="closeMenu()" aria-label="閉じる">×</button>
    </div>

    <div class="menu-scroll">
      <section class="menu-block">
        <h4>検索・並び替え</h4>
        <div class="menu-grid">
          <input id="searchBox" type="text" placeholder="温泉名・泉質・レビューで検索" oninput="renderOnsenList()">
          <select id="sortSelect" onchange="renderOnsenList()">
            <option value="default">並び替えなし</option>
            <option value="name">名前順</option>
            <option value="type">泉質順</option>
            <option value="priceAsc">価格が安い順</option>
            <option value="ratingDesc">評価が高い順</option>
          </select>
        </div>
        <div class="menu-note">価格や評価が未入力の行は自動で末尾寄りに並びます。</div>
      </section>

      <section class="menu-block">
        <h4>温泉一覧</h4>
        <div id="onsenList" class="onsen-list"></div>
      </section>
    </div>
  </aside>

  <div id="map"></div>

  <div class="main">
    <div class="selected-panel">
      <div class="selected-title">選択ルート</div>
      <div id="selected"></div>
    </div>
  </div>



  <div id="detailOverlay" class="detail-overlay" onclick="closeDetail()"></div>
  <section id="detailSheet" class="detail-sheet" aria-hidden="true">
    <div class="detail-head">
      <div class="detail-handle"></div>
      <div class="detail-title-row">
        <h3 id="detailTitle" class="detail-title">温泉詳細</h3>
        <button class="detail-close" onclick="closeDetail()" aria-label="詳細を閉じる">×</button>
      </div>
    </div>
    <div id="detailBody" class="detail-body"></div>
  </section>


  <div class="footer">
    <button onclick="drawRoute()" class="icon-btn route-btn" aria-label="ルート表示">
      <svg viewBox="0 0 24 24"><path d="M3 12h18M12 3l9 9-9 9"/></svg>
      <span>ルート</span>
    </button>

    <button onclick="optimizeRoute()" class="icon-btn opt-btn" aria-label="最適化">
      <svg viewBox="0 0 24 24"><path d="M4 6h16M4 12h10M4 18h7"/></svg>
      <span>最適化</span>
    </button>

    <button onclick="clearRoute()" class="icon-btn clear-btn" aria-label="リセット">
      <svg viewBox="0 0 24 24"><path d="M3 6h18M8 6v12M16 6v12"/></svg>
      <span>リセット</span>
    </button>

    <button onclick="generateRoute()" class="icon-btn route-btn" aria-label="Google Mapでルート作成">
      <svg viewBox="0 0 24 24"><path d="M4 4h16v16H4zM8 12h8"/></svg>
      <span>Google</span>
    </button>

    <button id="toggleStart" class="icon-btn toggle-btn" onclick="toggleStartMode()" aria-label="現在地から検索を切り替え">
      <svg viewBox="0 0 24 24"><path d="M12 2v20M2 12h20"/></svg>
      <span>現在地</span>
    </button>
  </div>
</div>

<script>
const isMobile = window.matchMedia("(pointer: coarse)").matches;
if(isMobile) document.body.classList.add("mobile");

const PW_HASH = "b25zZW4=";
const MAPTILER_KEY = "5803br5MI3qRfp9DVSHL";

let map;
let onsens = [];
let selected = [];
let startFromCurrent = false;

const typeColor = {
  "銭湯": "#7f8c8d",
  "単純温泉": "#87ceeb",
  "塩化物泉": "#e74c3c",
  "炭酸水素塩泉": "#1abc9c",
  "硫酸塩泉": "#9b59b6",
  "二酸化炭素泉": "#3498db",
  "含鉄泉": "#d35400",
  "硫黄泉": "#f1c40f",
  "酸性泉": "#e84393",
  "放射能泉": "#27ae60",
  "含よう素泉": "#e67e22"
};

function showLoading(v){
  document.getElementById("loading").classList.toggle("active", v);
}

function fitRoute(coords){
  if(coords.length < 2) return;
  const bounds = new maplibregl.LngLatBounds(coords[0], coords[0]);
  coords.forEach(c => bounds.extend(c));
  map.fitBounds(bounds, {
    padding: {
      top: 60,
      bottom: isMobile ? 120 : 220,
      left: 40,
      right: 40
    },
    duration: 600
  });
}

function login(){
  const pw = document.getElementById("pw");
  if(atob(PW_HASH) !== pw.value){
    alert("パスワードが違います");
    return;
  }

  const auth = document.getElementById("auth");
  const app = document.getElementById("app");

  auth.style.opacity = 0;
  auth.style.transform = "scale(1.05)";

  setTimeout(() => {
    auth.style.display = "none";
    app.style.opacity = 1;
    app.style.transform = "translateY(0) scale(1)";
    init();
  }, 500);
}

async function init(){
  await loadCSV();

  map = new maplibregl.Map({
    container: "map",
    style: `https://api.maptiler.com/maps/streets/style.json?key=${MAPTILER_KEY}`,
    center: [137, 36],
    zoom: 5
  });

  map.on("load", () => {
    map.resize();
    setupMap();
    renderSelected();
    renderOnsenList();

    map.addSource("route", {
      type: "geojson",
      data: { type: "FeatureCollection", features: [] }
    });

    map.addLayer({
      id: "route",
      type: "line",
      source: "route",
      paint: {
        "line-color": "#007aff",
        "line-width": 4
      }
    });
  });
}

async function loadCSV(){
  const txt = await (await fetch("onsen_stage4.csv")).text();
  onsens = parseCSV(txt).map((row, i) => ({
    id: i,
    name: (row.name || "").trim(),
    lat: Number(row.lat),
    lng: Number(row.lng),
    type: (row.type || "").trim(),
    price: (row.price || "").trim(),
    rating: (row.rating || "").trim(),
    review: (row.review || "").trim(),
    description: (row.description || "").trim(),
    address: (row.address || "").trim(),
    hours: (row.hours || "").trim(),
    url: (row.url || "").trim()
  })).filter(o => Number.isFinite(o.lat) && Number.isFinite(o.lng) && o.name);
}

function parseCSV(text){
  const rows = [];
  let row = [];
  let value = "";
  let inQuotes = false;

  for(let i = 0; i < text.length; i++){
    const ch = text[i];
    const next = text[i + 1];

    if(ch === '"'){
      if(inQuotes && next === '"'){
        value += '"';
        i++;
      }else{
        inQuotes = !inQuotes;
      }
    }else if(ch === ',' && !inQuotes){
      row.push(value);
      value = "";
    }else if((ch === '\n' || ch === '\r') && !inQuotes){
      if(ch === '\r' && next === '\n') i++;
      row.push(value);
      value = "";
      if(row.some(cell => cell !== "")) rows.push(row);
      row = [];
    }else{
      value += ch;
    }
  }

  if(value !== "" || row.length){
    row.push(value);
    if(row.some(cell => cell !== "")) rows.push(row);
  }

  if(!rows.length) return [];
  const headers = rows[0].map(h => h.trim());
  return rows.slice(1).map(cols => {
    const obj = {};
    headers.forEach((header, idx) => {
      obj[header] = (cols[idx] || "").trim();
    });
    return obj;
  });
}

function setupMap(){
  map.addSource("onsen", {
    type: "geojson",
    data: geo(),
    cluster: true,
    clusterMaxZoom: 10,
    clusterRadius: 40
  });

  map.addLayer({
    id: "cluster",
    type: "circle",
    source: "onsen",
    filter: ["has", "point_count"],
    paint: {"circle-color": "#636e72", "circle-radius": 18}
  });

  map.addLayer({
    id: "cluster-count",
    type: "symbol",
    source: "onsen",
    filter: ["has", "point_count"],
    layout: {"text-field": ["get", "point_count"]},
    paint: {"text-color": "#fff"}
  });

  map.addLayer({
    id: "points",
    type: "circle",
    source: "onsen",
    filter: ["!has", "point_count"],
    paint: {
      "circle-color": ["get", "color"],
      "circle-radius": 8
    }
  });

  map.addLayer({
    id: "selected",
    type: "circle",
    source: "onsen",
    filter: ["in", "id", -1],
    paint: {
      "circle-color": ["get", "color"],
      "circle-radius": 14,
      "circle-stroke-width": 3,
      "circle-stroke-color": "#f1c40f"
    }
  });

  map.addLayer({
    id: "order",
    type: "symbol",
    source: "onsen",
    filter: ["in", "id", -1],
    layout: {"text-field": ["get", "order"], "text-size": 14},
    paint: {"text-color": "#fff"}
  });

  map.addLayer({
    id: "label",
    type: "symbol",
    source: "onsen",
    filter: ["!has", "point_count"],
    layout: {
      "text-field": ["get", "name"],
      "text-size": 14,
      "text-offset": [0, 1.2]
    },
    paint: {
      "text-color": "#000",
      "text-halo-color": "#fff",
      "text-halo-width": 2
    }
  });

  map.moveLayer("selected");
  map.moveLayer("order");

  map.on("click", (e) => {
    const features = map.queryRenderedFeatures(
      [
        [e.point.x - 10, e.point.y - 10],
        [e.point.x + 10, e.point.y + 10]
      ],
      { layers: ["points"] }
    );

    if(features.length){
      const id = Number(features[0].properties.id);
      toggle(id, {showDetail:true, focus:false});
    }
  });

  map.on("click", "cluster", e => {
    const f = map.queryRenderedFeatures(e.point, { layers:["cluster"] })[0];
    map.getSource("onsen").getClusterExpansionZoom(f.properties.cluster_id, (err, zoom) => {
      if(err) return;
      map.easeTo({ center: f.geometry.coordinates, zoom });
    });
  });
}

function geo(){
  return {
    type: "FeatureCollection",
    features: onsens.map(o => ({
      type: "Feature",
      geometry: { type: "Point", coordinates: [o.lng, o.lat] },
      properties: {
        id: o.id,
        name: o.name,
        color: typeColor[o.type] || "#7f8c8d",
        order: selected.includes(o.id) ? String(selected.indexOf(o.id) + 1) : ""
      }
    }))
  };
}

function update(){
  if(!map || !map.getSource("onsen")) return;
  map.getSource("onsen").setData(geo());
  map.setFilter("selected", ["in", "id", ...selected]);
  map.setFilter("order", ["in", "id", ...selected]);
  renderSelected();
  renderOnsenList();
}

async function drawRoute(){
  if(selected.length < 2) return;
  showLoading(true);

  const coordPairs = selected.map(i => {
    const o = onsens[i];
    return [o.lng, o.lat];
  });

  fitRoute(coordPairs);

  const coords = coordPairs.map(c => c.join(","));
  const data = await (await fetch(`https://router.project-osrm.org/route/v1/driving/${coords.join(";")}?overview=full&geometries=geojson`)).json();

  map.getSource("route").setData({
    type: "Feature",
    geometry: data.routes[0].geometry
  });

  showLoading(false);
}

async function optimizeRoute(){
  if(selected.length < 2) return;
  showLoading(true);
  selected.sort((a,b) => onsens[a].lat - onsens[b].lat);
  update();
  await drawRoute();
}

function renderSelected(){
  if(isMobile) return;
  const el = document.getElementById("selected");

  if(!selected.length){
    el.innerHTML = '<div class="empty-note">地図またはメニュー一覧から温泉を選択してください。</div>';
    return;
  }

  el.innerHTML = selected.map(i => {
    const o = onsens[i];
    return `
      <div class="selected-item" onclick="showDetail(${i})" role="button" tabindex="0">
        <div class="selected-item-info">
          <div class="selected-item-title">${escapeHTML(o.name)}</div>
          <div class="selected-item-meta">${escapeHTML(o.type || "泉質未設定")} / ${escapeHTML(formatPrice(o.price))}</div>
        </div>
        <button class="remove-btn" onclick="event.stopPropagation(); removeItem(${i})" aria-label="${escapeAttr(o.name)} を削除">×</button>
      </div>
    `;
  }).join("");
}

function renderOnsenList(){
  const el = document.getElementById("onsenList");
  if(!el) return;

  const keyword = (document.getElementById("searchBox")?.value || "").trim().toLowerCase();
  const sort = document.getElementById("sortSelect")?.value || "default";

  let list = [...onsens];

  if(keyword){
    list = list.filter(o => {
      return [o.name, o.type, o.review, o.description, o.address]
        .filter(Boolean)
        .some(v => v.toLowerCase().includes(keyword));
    });
  }

  if(sort === "name"){
    list.sort((a,b) => a.name.localeCompare(b.name, "ja"));
  }else if(sort === "type"){
    list.sort((a,b) => (a.type || "").localeCompare(b.type || "", "ja"));
  }else if(sort === "priceAsc"){
    list.sort((a,b) => normalizePrice(a.price) - normalizePrice(b.price));
  }else if(sort === "ratingDesc"){
    list.sort((a,b) => normalizeRating(b.rating) - normalizeRating(a.rating));
  }

  if(!list.length){
    el.innerHTML = '<div class="no-result">該当する温泉がありません。</div>';
    return;
  }

  el.innerHTML = list.map(o => {
    const selectedClass = selected.includes(o.id) ? 'solid-btn is-selected' : 'solid-btn';
    const selectedLabel = selected.includes(o.id) ? '選択解除' : '選択';
    return `
      <article class="onsen-item">
        <div class="onsen-head">
          <div>
            <div class="onsen-name">${escapeHTML(o.name)}</div>
            <div class="onsen-type">
              <span class="onsen-type-dot" style="background:${typeColor[o.type] || '#7f8c8d'}"></span>
              <span>${escapeHTML(o.type || '泉質未設定')}</span>
            </div>
          </div>
        </div>

        <div class="onsen-mini">
          <div>価格: ${escapeHTML(formatPrice(o.price))}</div>
          <div>評価: ${escapeHTML(formatRating(o.rating))}</div>
          <div title="${escapeAttr(o.review || 'レビュー未設定')}">レビュー: ${escapeHTML(o.review || '未設定')}</div>
          <div title="${escapeAttr(o.hours || '営業時間未設定')}">営業時間: ${escapeHTML(o.hours || '未設定')}</div>
        </div>

        <div class="onsen-actions">
          <button class="ghost-btn" onclick="focusOnsen(${o.id}); showDetail(${o.id});">地図へ</button>
          <button class="ghost-btn" onclick="showDetail(${o.id})">詳細</button>
          <button class="${selectedClass}" onclick="toggle(${o.id}, {showDetail:true})">${selectedLabel}</button>
        </div>
      </article>
    `;
  }).join("");
}

function focusOnsen(id, closeMenuAfter = true){
  const o = onsens.find(x => x.id === id);
  if(!o || !map) return;
  map.easeTo({ center:[o.lng, o.lat], zoom: 11, duration: 700 });
  if(closeMenuAfter) closeMenu();
}

function removeItem(i){
  selected = selected.filter(x => x !== i);
  update();
}

function toggle(i, options = {}){
  const { showDetail: shouldShowDetail = false, focus = false } = options;

  if(selected.includes(i)){
    selected = selected.filter(x => x !== i);
  }else{
    selected.push(i);
  }

  update();

  if(focus) focusOnsen(i, false);
  if(shouldShowDetail) showDetail(i);
}

function clearRoute(){
  if(map?.getSource("route")){
    map.getSource("route").setData({ type:"FeatureCollection", features:[] });
  }
}

function toggleStartMode(){
  startFromCurrent = !startFromCurrent;
  document.getElementById("toggleStart").classList.toggle("active", startFromCurrent);
}

function generateRoute(){
  if(!selected.length) return;

  const names = selected.map(i => encodeURIComponent(onsens[i].name));
  const url = startFromCurrent
    ? `https://www.google.com/maps/dir/?api=1&origin=Current+Location&destination=${names.at(-1)}&waypoints=${names.slice(0,-1).join('|')}`
    : `https://www.google.com/maps/dir/?api=1&origin=${names[0]}&destination=${names.at(-1)}&waypoints=${names.slice(1,-1).join('|')}`;

  window.open(url);
}

function toggleMenu(){
  const menu = document.getElementById("sideMenu");
  const overlay = document.getElementById("menuOverlay");
  const opened = menu.classList.toggle("open");
  overlay.classList.toggle("show", opened);
  menu.setAttribute("aria-hidden", String(!opened));
}

function closeMenu(){
  document.getElementById("sideMenu").classList.remove("open");
  document.getElementById("menuOverlay").classList.remove("show");
  document.getElementById("sideMenu").setAttribute("aria-hidden", "true");
}


function showDetail(id){
  const o = onsens.find(x => x.id === id);
  if(!o) return;

  const body = document.getElementById("detailBody");
  const title = document.getElementById("detailTitle");
  const selectedNow = selected.includes(id);

  title.textContent = o.name;
  body.innerHTML = `
    <div class="detail-badges">
      <span class="detail-badge">
        <span class="onsen-type-dot" style="background:${typeColor[o.type] || '#7f8c8d'}"></span>
        <span>${escapeHTML(o.type || '泉質未設定')}</span>
      </span>
      <span class="detail-badge">価格: ${escapeHTML(formatPrice(o.price))}</span>
      <span class="detail-badge">評価: ${escapeHTML(formatRating(o.rating))}</span>
      <span class="detail-badge">${selectedNow ? '選択中' : '未選択'}</span>
    </div>

    <section class="detail-section">
      <h4>概要</h4>
      <div class="detail-value">${escapeHTML(o.description || o.review || '詳細説明は未設定です。')}</div>
    </section>

    <section class="detail-section">
      <h4>基本情報</h4>
      <div class="detail-grid">
        <div class="detail-field">
          <span class="detail-label">レビュー</span>
          <div class="detail-value">${escapeHTML(o.review || '未設定')}</div>
        </div>
        <div class="detail-field">
          <span class="detail-label">営業時間</span>
          <div class="detail-value">${escapeHTML(o.hours || '未設定')}</div>
        </div>
        <div class="detail-field">
          <span class="detail-label">住所</span>
          <div class="detail-value">${escapeHTML(o.address || '未設定')}</div>
        </div>
        <div class="detail-field">
          <span class="detail-label">座標</span>
          <div class="detail-value">${o.lat.toFixed(6)}, ${o.lng.toFixed(6)}</div>
        </div>
      </div>

      <div class="detail-actions">
        <button class="ghost-btn" onclick="focusOnsen(${id}, false)">地図へ移動</button>
        <button class="${selectedNow ? 'solid-btn is-selected' : 'solid-btn'}" onclick="toggle(${id}, {showDetail:true})">${selectedNow ? '選択解除' : 'ルートに追加'}</button>
      </div>
      ${o.url ? `<div class="detail-actions"><a class="detail-link" href="${escapeAttr(o.url)}" target="_blank" rel="noopener noreferrer">公式サイトを開く</a></div>` : ''}
    </section>
  `;

  document.getElementById("detailSheet").classList.add("open");
  document.getElementById("detailOverlay").classList.add("show");
  document.getElementById("detailSheet").setAttribute("aria-hidden", "false");
}

function closeDetail(){
  document.getElementById("detailSheet").classList.remove("open");
  document.getElementById("detailOverlay").classList.remove("show");
  document.getElementById("detailSheet").setAttribute("aria-hidden", "true");
}

function formatPrice(value){
  const n = Number(String(value).replace(/[^\d.]/g, ""));
  if(!Number.isFinite(n) || !value) return "未設定";
  return `${n.toLocaleString("ja-JP")}円`;
}

function formatRating(value){
  const n = Number(value);
  if(!Number.isFinite(n)) return "未設定";
  return n.toFixed(1);
}

function normalizePrice(value){
  const n = Number(String(value).replace(/[^\d.]/g, ""));
  return Number.isFinite(n) ? n : Number.POSITIVE_INFINITY;
}

function normalizeRating(value){
  const n = Number(value);
  return Number.isFinite(n) ? n : Number.NEGATIVE_INFINITY;
}

function escapeHTML(value){
  return String(value ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function escapeAttr(value){
  return escapeHTML(value).replace(/`/g, "&#96;");
}

document.addEventListener("keydown", (e) => {
  if(e.key === "Escape"){
    closeMenu();
    closeDetail();
  }
});
</script>
</body>
</html>
